{
  "title": "Microservices Overview",
  "uid": "microservices-overview",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate per Service (req/sec)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[5m])) by (service)",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate per Service (%)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~'5..'}[5m])) by (service) / sum(rate(http_requests_total[5m])) by (service) * 100",
          "legendFormat": "{{service}} error %"
        }
      ]
    },
    {
      "id": 3,
      "title": "P95 Latency per Service (ms)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (service, le)) * 1000",
          "legendFormat": "{{service}} p95"
        }
      ]
    },
    {
      "id": 4,
      "title": "Pod CPU Usage",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace='production'}[5m])) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "version": 1
}